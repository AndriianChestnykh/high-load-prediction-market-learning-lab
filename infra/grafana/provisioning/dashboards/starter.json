{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count[30s]))",
          "legendFormat": "RPS"
        }
      ],
      "title": "Request Rate (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[30s])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[30s])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[30s])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "title": "HTTP Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "PG Pool (app-side)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        { "expr": "pg_pool_total_connections",   "legendFormat": "total" },
        { "expr": "pg_pool_idle_connections",    "legendFormat": "idle" },
        { "expr": "pg_pool_waiting_clients",     "legendFormat": "waiting" }
      ],
      "title": "PG Pool Connections",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"playground\"}",
          "legendFormat": "pg_stat_activity ({{state}})"
        }
      ],
      "title": "Postgres Active Connections",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"playground\"}[30s])",
          "legendFormat": "commits/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"playground\"}[30s])",
          "legendFormat": "rollbacks/s"
        }
      ],
      "title": "Postgres Transactions/s",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Redis",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 6,
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[30s])",
          "legendFormat": "ops/s"
        }
      ],
      "title": "Redis Ops/s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 7,
      "targets": [
        { "expr": "redis_keyspace_hits_total",   "legendFormat": "hits" },
        { "expr": "redis_keyspace_misses_total", "legendFormat": "misses" }
      ],
      "title": "Redis Cache Hits vs Misses",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "decbytes" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 8,
      "targets": [
        { "expr": "redis_memory_used_bytes",     "legendFormat": "used" },
        { "expr": "redis_memory_max_bytes",      "legendFormat": "max" }
      ],
      "title": "Redis Memory",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 103,
      "title": "Node.js Process",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "id": 9,
      "targets": [
        {
          "expr": "rate(node_process_cpu_seconds_total[30s])",
          "legendFormat": "CPU"
        }
      ],
      "title": "Node CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "decbytes" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "id": 10,
      "targets": [
        {
          "expr": "node_nodejs_heap_used_bytes",
          "legendFormat": "heap used"
        },
        {
          "expr": "node_nodejs_heap_size_total_bytes",
          "legendFormat": "heap total"
        }
      ],
      "title": "Node Heap Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "id": 11,
      "targets": [
        {
          "expr": "node_nodejs_active_handles_total",
          "legendFormat": "active handles"
        },
        {
          "expr": "node_nodejs_active_requests_total",
          "legendFormat": "active requests"
        }
      ],
      "title": "Node Event Loop Activity",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
