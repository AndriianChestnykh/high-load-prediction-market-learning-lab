{
  "uid": "predmarket-pg-pgb",
  "title": "Predmarket — Postgres + PgBouncer",
  "tags": ["predmarket", "phase2"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "PgBouncer clients waiting (cl_waiting)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pgbouncer_pools_client_waiting_connections)",
          "legendFormat": "cl_waiting"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "PgBouncer connections (clients vs servers)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 18, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pgbouncer_pools_client_active_connections)",
          "legendFormat": "client active"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pgbouncer_pools_client_waiting_connections)",
          "legendFormat": "client waiting"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pgbouncer_pools_server_active_connections)",
          "legendFormat": "server active"
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pgbouncer_pools_server_idle_connections)",
          "legendFormat": "server idle"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Postgres backends (predmarket)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_stat_database_numbackends{datname=\"predmarket\"}",
          "legendFormat": "backends"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Transaction rate (commit / rollback)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 9, "x": 6, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_xact_commit{datname=\"predmarket\"}[1m])",
          "legendFormat": "commit/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"predmarket\"}[1m])",
          "legendFormat": "rollback/s"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Deadlocks & conflicts / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 9, "x": 15, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_deadlocks{datname=\"predmarket\"}[1m])",
          "legendFormat": "deadlocks/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_conflicts{datname=\"predmarket\"}[1m])",
          "legendFormat": "conflicts/s"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tuples fetched / returned / sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_tup_fetched{datname=\"predmarket\"}[1m])",
          "legendFormat": "fetched/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_tup_returned{datname=\"predmarket\"}[1m])",
          "legendFormat": "returned/s"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Exporter up (postgres / pgbouncer)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"postgres\"}",
          "legendFormat": "postgres_exporter"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"pgbouncer\"}",
          "legendFormat": "pgbouncer_exporter"
        }
      ]
    }
  ]
}
