# App runtime traffic -> PgBouncer (:6432) from Phase 1 onward.
DATABASE_URL=postgres://lab:lab@localhost:6432/predmarket
# Migrations / admin / seed -> direct Postgres (:5432), bypassing PgBouncer.
DIRECT_DATABASE_URL=postgres://lab:lab@localhost:5432/predmarket
REDIS_URL=redis://localhost:6379
PORT=3000
