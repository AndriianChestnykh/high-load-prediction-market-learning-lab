# ── Postgres ────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432          # 5432 = direct Postgres | 6432 = via PgBouncer
PG_USER=app
PG_PASSWORD=app
PG_DATABASE=playground

# App-side connection pool (node-postgres)
PG_POOL_MAX=10
PG_STATEMENT_TIMEOUT=5000   # ms; 0 = disabled

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── App ──────────────────────────────────────────────────────────────────────
APP_PORT=8080
METRICS_PORT=9100     # /metrics on a dedicated port so load traffic doesn't inflate counts

# ── Observability ────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
