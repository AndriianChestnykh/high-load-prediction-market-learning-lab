{
  "name": "prediction-market-lab",
  "version": "0.1.0",
  "description": "High-load infra learning lab — prediction market with LMSR",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate": "node-pg-migrate up",
    "migrate:create": "node-pg-migrate create",
    "seed": "node scripts/seed.js",
    "db:reset": "node-pg-migrate down --count 999 && node-pg-migrate up && node scripts/seed.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.3.2",
    "node-pg-migrate": "^7.3.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  },
  "node-pg-migrate": {
    "migrations-dir": "migrations",
    "database-url-var": "DIRECT_DATABASE_URL"
  }
}
